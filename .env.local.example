# Supabase Environment Variables for Local Development
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Stream API Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-cloudflare-stream-token
CLOUDFLARE_WEBHOOK_SECRET=your-webhook-secret-here

# Test Configuration
NODE_ENV=development
TEST_USER_EMAIL=test@rovrov.local