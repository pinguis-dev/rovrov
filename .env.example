# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Access Token for MCP Server
# Get this from your Supabase account settings at https://supabase.com/dashboard/account/tokens
# This is used by the Claude Code MCP server for database management
SUPABASE_ACCESS_TOKEN=your_personal_access_token

# These environment variables are used by:
# 1. The React Native app for Supabase client initialization (URL + ANON_KEY)
# 2. The Claude Code MCP server for database management (ACCESS_TOKEN)